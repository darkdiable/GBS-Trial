<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>
        <RollingFile name="FILE" fileName="/Users/bilei/development/workspace-intellij/study/myStudy/log4j2.log"
                     filePattern="/Users/bilei/development/workspace-intellij/study/myStudy/log4j2-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger{36}:%L - %m%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy modulate="true" interval="24" />
                <SizeBasedTriggeringPolicy size="100 MB"/>
            </Policies>
        </RollingFile>
    </Appenders>
    <Loggers>
        <Logger name="me.darkdiable.www" level="INFO" additivity="false">
            <AppenderRef ref="FILE"/>
            <AppenderRef ref="Console"/>
        </Logger>
        <Root level="INFO" >
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>